# Anthropic
ANTHROPIC_API_KEY=

# Brave Search
BRAVE_API_KEY=

# Semantic Scholar (optional, free API has no key)

# ---------------------------------------------------------------------------
# Agent-stage overrides (optional)
# ---------------------------------------------------------------------------
# Pattern: DECISIONLAB_<STAGE>_{MODEL,MAX_ITERATIONS,MAX_TOKENS}
# Stages: RESEARCHER, DEEP_RESEARCHER, DEEP_RESEARCHER_SUMMARY,
#         FORMALIZER, REASONER, BUILDER
#
# Defaults (live in src/decisionlab/config.py):
#   RESEARCHER              claude-sonnet-4-6   iters=10  tokens=4096
#   DEEP_RESEARCHER         claude-sonnet-4-6   iters=7   tokens=16384
#   DEEP_RESEARCHER_SUMMARY claude-haiku-4-5    iters=1   tokens=300
#   FORMALIZER              claude-opus-4-6     iters=5   tokens=16384
#   REASONER                claude-opus-4-6     iters=5   tokens=16384
#   BUILDER                 claude-sonnet-4-6   iters=25  tokens=16384

# Cheap smoke-test example (uncomment to use):
# DECISIONLAB_FORMALIZER_MODEL=claude-sonnet-4-6
# DECISIONLAB_REASONER_MODEL=claude-sonnet-4-6
# DECISIONLAB_BUILDER_MAX_ITERATIONS=10
