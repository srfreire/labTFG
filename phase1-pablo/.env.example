# Anthropic / OpenRouter
ANTHROPIC_BASE_URL="https://openrouter.ai/api"
ANTHROPIC_API_KEY=

# Embeddings + retrieval
VOYAGE_API_KEY=
ZEROENTROPY_API_KEY=

# Knowledge graph
NEO4J_PASSWORD=

# Tavily Search (primary web_search — pipeline falls back to DuckDuckGo without a key)
TAVILY_API_KEY=

# Semantic Scholar (optional, free API has no key)

# ---------------------------------------------------------------------------
# Agent-stage overrides
# ---------------------------------------------------------------------------
# Pattern: DECISIONLAB_<STAGE>_{MODEL,MAX_ITERATIONS,MAX_TOKENS}
# Stages: RESEARCHER, DEEP_RESEARCHER, DEEP_RESEARCHER_SUMMARY,
#         FORMALIZER, REASONER, BUILDER
# All lines below are the defaults from src/decisionlab/config.py — edit to taste.

DECISIONLAB_RESEARCHER_MODEL=anthropic/claude-sonnet-4.6
DECISIONLAB_RESEARCHER_MAX_ITERATIONS=10
DECISIONLAB_RESEARCHER_MAX_TOKENS=16384

DECISIONLAB_DEEP_RESEARCHER_MODEL=anthropic/claude-sonnet-4.6
DECISIONLAB_DEEP_RESEARCHER_MAX_ITERATIONS=7
DECISIONLAB_DEEP_RESEARCHER_MAX_TOKENS=16384

DECISIONLAB_DEEP_RESEARCHER_SUMMARY_MODEL=anthropic/claude-haiku-4.5
DECISIONLAB_DEEP_RESEARCHER_SUMMARY_MAX_ITERATIONS=1
DECISIONLAB_DEEP_RESEARCHER_SUMMARY_MAX_TOKENS=300

DECISIONLAB_FORMALIZER_MODEL=anthropic/claude-opus-4.6
DECISIONLAB_FORMALIZER_MAX_ITERATIONS=8
DECISIONLAB_FORMALIZER_MAX_TOKENS=16384

DECISIONLAB_REASONER_MODEL=anthropic/claude-opus-4.6
DECISIONLAB_REASONER_MAX_ITERATIONS=8
DECISIONLAB_REASONER_MAX_TOKENS=16384

DECISIONLAB_BUILDER_MODEL=anthropic/claude-sonnet-4.6
DECISIONLAB_BUILDER_MAX_ITERATIONS=25
DECISIONLAB_BUILDER_MAX_TOKENS=16384

# ---------------------------------------------------------------------------
# Auxiliary model slots (role-named — swap any provider via env)
# ---------------------------------------------------------------------------
# KNOWLEDGE_FAST       — Formalizer/Builder extraction, importance scoring,
#                        NER, CRAG, reflections (Haiku 4.5)
# KNOWLEDGE_STRUCTURED  — Researcher/Reasoner extraction + conflict
#                        resolution between memories (Sonnet 4.6)
# FEEDBACK              — feedback classifier (router re-execution decisions)

DECISIONLAB_KNOWLEDGE_FAST_MODEL=anthropic/claude-haiku-4.5
DECISIONLAB_KNOWLEDGE_STRUCTURED_MODEL=anthropic/claude-sonnet-4.6
DECISIONLAB_FEEDBACK_MODEL=anthropic/claude-haiku-4.5

# Optional memory-layer token caps. Lower these for constrained eval retries;
# defaults stay generous for normal runs.
DECISIONLAB_EXTRACTION_MAX_TOKENS=16384
DECISIONLAB_IMPORTANCE_MAX_TOKENS=16384
DECISIONLAB_CONFLICT_CLASSIFY_MAX_TOKENS=4096
DECISIONLAB_REFLECTION_MAX_TOKENS=4096
DECISIONLAB_CONTRADICTION_MAX_TOKENS=4096
