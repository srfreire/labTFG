@startuml
!pragma layout smetana
left to right direction
skinparam backgroundColor white
skinparam dpi 190
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam component {
  BorderColor #334155
  BackgroundColor #EEF2FF
}
skinparam database {
  BorderColor #166534
  BackgroundColor #ECFDF5
}

component "Router" as Router
component "Agentes del pipeline" as Agents

component "MemoryAgent\n<<component>>\nExtractor\nCanonicalizador\nResolver\nWriter" as Memory
component "Retriever\n<<component>>\nBusqueda hibrida\nReranking\nContextBuilder" as Retriever

database "MinIO\nartefactos completos" as MinIO
database "PostgreSQL\nmetadatos\nconfianza\nvigencia" as PG
database "Neo4j\ngrafo de conocimiento" as Neo4j
database "Qdrant\nvectores\nBM25" as Qdrant

Router --> Memory : artefacto aceptado
Memory --> MinIO : fuente
Memory --> PG : revision
Memory --> Neo4j : relaciones
Memory --> Qdrant : hechos

Agents --> Retriever : retrieve_knowledge\ncontexto con procedencia
Retriever --> Neo4j : relaciones
Retriever --> Qdrant : candidatos
Retriever --> PG : confianza
@enduml
