@startuml
!pragma layout smetana
top to bottom direction
skinparam backgroundColor white
skinparam dpi 180
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #334155
  BackgroundColor #F8FAFC
}
skinparam component {
  BorderColor #334155
  BackgroundColor #EEF2FF
}
skinparam node {
  BorderColor #334155
  BackgroundColor #EFF6FF
}

node "Investigador actual" as Actual {
  component "Buscar en muchas fuentes" as A1
  component "Contrastar" as A2
  component "Elegir informacion util" as A3
  component "Entender" as A4
  component "Interpretar" as A5
  component "Transformar" as A6
  component "Usar" as A7
}

node "Investigador x10" as X10 {
  component "Describir" as B1
  component "Sistema de agentes\nbusca, contrasta, elige,\nentiende, interpreta y transforma" as Sys #ECFDF5
  component "Revisar" as B2
  component "Usar" as B3
}

A1 -down-> A2
A2 -down-> A3
A3 -down-> A4
A4 -down-> A5
A5 -down-> A6
A6 -down-> A7

B1 -down-> Sys
Sys -down-> B2
B2 -down-> B3

Actual -[hidden]right- X10
@enduml
