@startuml
!pragma layout smetana
left to right direction
skinparam backgroundColor white
skinparam dpi 190
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam component {
  BorderColor #334155
  BackgroundColor #EEF2FF
}
skinparam database {
  BorderColor #166534
  BackgroundColor #ECFDF5
}

component "Artefacto aceptado\ninforme, formulacion,\nspec o modelo" as Art
component "MemoryAgent\nextrae, canonicaliza,\nresuelve y escribe" as MA

database "Memoria relacional\nPostgreSQL\nrevision, confianza,\nvigencia y supersesion" as PG
database "Memoria de grafo\nNeo4j\nparadigmas, papers,\nvariables y relaciones" as Neo
database "Memoria vectorial\nQdrant\nhechos densos + BM25\ncon procedencia" as Qd

database "MinIO\nartefacto completo\nfuente auditable" as MinIO

Art --> MA
MA --> PG : registra ciclo de vida
MA --> Neo : crea nodos y relaciones\ncon slugs canonicos
MA --> Qd : indexa hechos\nrecuperables
Art --> MinIO : se conserva integro
@enduml
