@startuml
!pragma teoz true
skinparam backgroundColor white
skinparam dpi 210
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam sequence {
  ArrowColor #334155
  LifeLineBorderColor #94A3B8
  ParticipantBorderColor #334155
  ParticipantBackgroundColor #F8FAFC
  ActorBorderColor #334155
  ActorBackgroundColor #ECFEFF
  DatabaseBorderColor #166534
  DatabaseBackgroundColor #ECFDF5
}

actor "Usuario" as User
participant "Router" as Router
participant "Agentes especializados" as Agents
participant "MemoryAgent" as Memory
database "Artefactos y estado\nMinIO + PostgreSQL" as Store
database "Memoria recuperable\nNeo4j + Qdrant" as KG
participant "Laboratorio virtual" as Lab

User -> Router : descripcion inicial
Router -> Store : crear run y estado inicial
Router -> KG : recuperar contexto previo
KG --> Router : hechos y relaciones

Router -> Agents : Researcher investiga paradigmas
Agents -> Store : guardar informe y deep reports
Agents --> User : paradigmas revisables
User -> Router : aprobar o pedir correccion

Router -> Agents : Formalizer genera formulaciones
Agents -> Store : guardar formulaciones
Agents --> User : formulaciones revisables
User -> Router : seleccionar formulaciones

Router -> Agents : Reasoner adapta al entorno
Agents -> Store : guardar env spec y specs tecnicas
Agents --> User : specs revisables
User -> Router : aprobar o pedir rerun

Router -> Agents : Builder genera modelo y tests
Agents -> Store : guardar codigo, tests y resultado
Agents --> User : modelo revisable
User -> Router : aprobar modelo

Router -> Memory : consolidar artefactos aceptados
Memory -> Store : registrar procedencia y metadatos
Memory -> KG : escribir nodos, relaciones y hechos

Router -> Lab : registrar modelo compatible
Lab -> Store : cargar DecisionModel
@enduml
