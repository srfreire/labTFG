@startuml
!pragma teoz true
hide footbox
skinparam backgroundColor white
skinparam dpi 210
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam sequence {
  ArrowColor #334155
  LifeLineBorderColor #94A3B8
  ParticipantBorderColor #334155
  ParticipantBackgroundColor #F8FAFC
  ActorBorderColor #334155
  ActorBackgroundColor #ECFEFF
  DatabaseBorderColor #166534
  DatabaseBackgroundColor #ECFDF5
}

participant "Deep report aceptado\ndrift diffusion model" as Art
participant "MemoryAgent" as Memory
database "MinIO" as MinIO
database "PostgreSQL" as PG
database "Neo4j" as Neo
database "Qdrant" as Qd
participant "Run futura\nparadigma parecido" as Run

Art -> Memory : conocimiento aceptado tras revision
Memory -> MinIO : documento integro (fuente)
Memory -> PG : revision aceptada, confianza y vigencia
Memory -> Neo : nodos y relaciones con slugs canonicos
Memory -> Qd : hecho denso + BM25

Run -> Neo : retrieve_knowledge
Run -> Qd : retrieve_knowledge
Neo --> Run : hechos y relaciones
Qd --> Run : contexto con procedencia
@enduml
