@startuml
!pragma layout smetana
left to right direction
skinparam backgroundColor white
skinparam dpi 180
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #334155
  BackgroundColor #F8FAFC
}
skinparam component {
  BorderColor #334155
  BackgroundColor #EEF2FF
}
skinparam node {
  BorderColor #334155
  BackgroundColor #EFF6FF
}
skinparam database {
  BorderColor #166534
  BackgroundColor #ECFDF5
}
skinparam actor {
  BorderColor #334155
  BackgroundColor #F8FAFC
}

actor "Investigador\n(Eduardo)" as Edu

node "Fase 1 (Pablo)" as F1 {
  component "Revision de literatura" as F1a
  component "Formalizacion de\nmodelos computacionales" as F1b
  component "Generacion de\nmodelos ejecutables" as F1c
}

node "Fase 2 (Juan)" as F2 {
  component "Simulacion" as F2a
  component "Analisis de resultados" as F2b
}

database "Memoria\ncross ejecucion" as Mem

Edu --> F1 : describe el paradigma
F1a --> F1b
F1b --> F1c
F1 --> F2 : modelos de decision
F2a --> F2b
F2 --> Edu : informes y observaciones
F1 <--> Mem : conocimiento aceptado
F2 --> Mem : observaciones
@enduml
