@startuml
!pragma layout smetana
skinparam backgroundColor white
skinparam dpi 180
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #334155
  FontSize 11
  DiamondBackgroundColor #FEF3C7
  DiamondBorderColor #92400E
  StartColor #0F766E
  EndColor #B91C1C
}

|Usuario|
start
:Describe problema;

|Router|
:Crea run y clasifica;

|Agentes|
:Researcher investiga paradigmas;

|Usuario|
:Revisa paradigmas;

|Agentes|
:Formalizer genera formulaciones;

|Usuario|
:Selecciona formulaciones;

|Router|
:Solicita especificacion de entorno;

|Usuario|
:Valida env_spec;

|Agentes|
:Reasoner adapta al entorno;

|Usuario|
:Revisa spec tecnica;

|Agentes|
:Builder genera codigo y tests;

|Usuario|
:Revisa modelo ejecutable;

|Router|
:Registra modelos aprobados;
note right
  Si una puerta se rechaza,
  el Router reprograma la
  etapa afectada.
end note

|Memoria|
:Consolida artefactos aceptados;
stop
@enduml
