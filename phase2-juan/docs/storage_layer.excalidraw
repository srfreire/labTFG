    {
      "id": "1087b7fe6e754691",
      "type": "text",
      "x": 60,
      "y": 1075,
      "width": 1360,
      "height": 16,
      "text": "Regla mental:   Postgres = 'el qu\u00e9 + d\u00f3nde' (metadatos, joins, statuses)   \u00b7   MinIO = 'el contenido' (blobs, JSONs, PDFs)",
      "originalText": "Regla mental:   Postgres = 'el qu\u00e9 + d\u00f3nde' (metadatos, joins, statuses)   \u00b7   MinIO = 'el contenido' (blobs, JSONs, PDFs)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#9399b2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
