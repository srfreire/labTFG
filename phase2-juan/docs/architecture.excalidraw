    {
      "id": "667d3b1e38e048e9",
      "type": "text",
      "x": 80,
      "y": 850,
      "width": 1240,
      "height": 16,
      "text": "Capas:   gris = interfaz   \u00b7   azul = orquestador   \u00b7   morado = agentes   \u00b7   \u00e1mbar = motor de simulaci\u00f3n   \u00b7   verde = knowledge / storage",
      "originalText": "Capas:   gris = interfaz   \u00b7   azul = orquestador   \u00b7   morado = agentes   \u00b7   \u00e1mbar = motor de simulaci\u00f3n   \u00b7   verde = knowledge / storage",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#9399b2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
