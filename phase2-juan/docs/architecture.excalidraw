    {
      "id": "13bc4eeaa12a4465",
      "type": "text",
      "x": 80,
      "y": 872,
      "width": 1240,
      "height": 16,
      "text": "Flechas:   lavanda = delegaci\u00f3n pipeline   \u00b7   \u00e1mbar = datos de simulaci\u00f3n   \u00b7   rosa = write KG   \u00b7   cyan = read KG",
      "originalText": "Flechas:   lavanda = delegaci\u00f3n pipeline   \u00b7   \u00e1mbar = datos de simulaci\u00f3n   \u00b7   rosa = write KG   \u00b7   cyan = read KG",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
