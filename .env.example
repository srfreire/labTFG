# Postgres
POSTGRES_USER=labtfg
POSTGRES_PASSWORD=labtfg
POSTGRES_DB=labtfg

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=labtfg

# Connection strings (used by application services)
POSTGRES_DSN=postgresql+asyncpg://labtfg:labtfg@localhost:5432/labtfg
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Neo4j (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=labtfg-neo4j

# Eval-KG segregation marker — required when running eval suites with
# `reset_kg_before: true` (slug-accuracy, cumulative-growth). The runner
# refuses to wipe Neo4j unless this marker is set OR the URI / database
# name contains "eval". Set to 1 only when this Neo4j instance is
# dedicated to evals.
# LABTFG_EVAL_KG=1

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333

# API Keys (required for LLM calls)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Voyage AI (embeddings + reranking — required for knowledge features)
# VOYAGE_API_KEY=your-voyage-api-key-here
# ZEROENTROPY_API_KEY=your-zeroentropy-api-key-here

# Knowledge Backbone — Phase 2 simulation observations
# (see docs/specs/sim-memory/ for details)
# When true, simulation Tracker outputs are written to the knowledge store
# on namespace=simulation. Requires Qdrant + Postgres + the Voyage keys above.
ENABLE_KNOWLEDGE_WRITE=false

# Knowledge Backbone — Phase 2 context retrieval
# (see docs/specs/sim-recall/ for details)
# When true, Architect/Analyst/Reporter can query the Knowledge Backbone
# via retrieve_context. Requires Neo4j + Qdrant + the Voyage keys above.
ENABLE_KNOWLEDGE_READ=false
